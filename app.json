{
  "expo": {
    "name": "Recharge Light",
    "slug": "rechargelight-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/rechargelight-logo.png",
    "scheme": "rechargelight",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rechargelight.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan QR codes for payments",
        "NSPhotoLibraryUsageDescription": "Upload profile photos"
      }
    },
    "android": {
      "package": "com.rechargelight.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/rechargelight-logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/rechargelight-logo.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "rechargelight-app"
      }
    }
  }
}
